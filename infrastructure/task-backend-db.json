{
  "family": "tienda-perritos-backend-db",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::283214265663:role/LabRole",
  "taskRoleArn": "arn:aws:iam::283214265663:role/LabRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "283214265663.dkr.ecr.us-east-1.amazonaws.com/tienda-perritos-backend:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 3001, "hostPort": 3001, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "localhost" },
        { "name": "DB_USER", "value": "root" },
        { "name": "DB_NAME", "value": "tienda_perritos" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "PORT", "value": "3001" }
      ],
      "secrets": [
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:283214265663:secret:tienda-perritos/db-password-qy9haD" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs-tienda-perritos-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      },
      "dependsOn": [
        { "containerName": "db", "condition": "HEALTHY" }
      ]
    },
    {
      "name": "db",
      "image": "283214265663.dkr.ecr.us-east-1.amazonaws.com/tienda-perritos-db:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 3306, "hostPort": 3306, "protocol": "tcp" }
      ],
      "secrets": [
        { "name": "MYSQL_ROOT_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:283214265663:secret:tienda-perritos/db-password-qy9haD" }
      ],
      "environment": [
        { "name": "MYSQL_DATABASE", "value": "tienda_perritos" }
      ],
      "healthCheck": {
        "command": ["CMD", "mysqladmin", "ping", "-h", "localhost"],
        "interval": 10,
        "timeout": 5,
        "retries": 5
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs-tienda-perritos-db",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "db"
        }
      }
    }
  ]
}
