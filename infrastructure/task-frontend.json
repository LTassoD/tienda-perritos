{
  "family": "tienda-perritos-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::283214265663:role/LabRole",
  "taskRoleArn": "arn:aws:iam::283214265663:role/LabRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "283214265663.dkr.ecr.us-east-1.amazonaws.com/tienda-perritos-frontend:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 80, "hostPort": 80, "protocol": "tcp" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "ecs-tienda-perritos-frontend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
}
